  "fixed_sql": [
    {
      "name": "boards",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"boards\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL, \"locale\" TEXT NOT NULL DEFAULT 'en', \"grid_rows\" INTEGER NOT NULL, \"grid_cols\" INTEGER NOT NULL, \"is_root\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_root\" IN (0, 1)), \"created_at\" TEXT NOT NULL DEFAULT (CURRENT_TIMESTAMP), \"updated_at\" TEXT NOT NULL DEFAULT (CURRENT_TIMESTAMP));"
        }
      ]
    },
    {
      "name": "images",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"images\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"path\" TEXT NOT NULL, \"content_type\" TEXT NOT NULL, \"width\" INTEGER NOT NULL, \"height\" INTEGER NOT NULL, \"license\" TEXT NULL, \"attribution\" TEXT NULL);"
        }
      ]
    },
    {
      "name": "sounds",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"sounds\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"path\" TEXT NOT NULL, \"content_type\" TEXT NOT NULL, \"duration_ms\" INTEGER NOT NULL);"
        }
      ]
    },
    {
      "name": "buttons",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"buttons\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"board_id\" INTEGER NOT NULL REFERENCES boards (id) ON DELETE CASCADE, \"label\" TEXT NOT NULL, \"vocalization\" TEXT NULL, \"display_text\" TEXT NULL, \"hidden\" INTEGER NOT NULL DEFAULT 0 CHECK (\"hidden\" IN (0, 1)), \"is_system\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_system\" IN (0, 1)), \"user_edited\" INTEGER NOT NULL DEFAULT 0 CHECK (\"user_edited\" IN (0, 1)), \"priority\" INTEGER NOT NULL DEFAULT 1000, \"background_color\" TEXT NULL, \"border_color\" TEXT NULL, \"image_id\" INTEGER NULL REFERENCES images (id) ON DELETE SET NULL, \"sound_id\" INTEGER NULL REFERENCES sounds (id) ON DELETE SET NULL, \"load_board_id\" INTEGER NULL, \"created_at\" TEXT NOT NULL DEFAULT (CURRENT_TIMESTAMP), \"updated_at\" TEXT NOT NULL DEFAULT (CURRENT_TIMESTAMP));"
        }
      ]
    },
    {
      "name": "grid_slots",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"grid_slots\" (\"board_id\" INTEGER NOT NULL REFERENCES boards (id) ON DELETE CASCADE, \"row_index\" INTEGER NOT NULL, \"col_index\" INTEGER NOT NULL, \"button_id\" INTEGER NULL REFERENCES buttons (id) ON DELETE SET NULL, PRIMARY KEY (\"board_id\", \"row_index\", \"col_index\"));"
        }
      ]
    },
    {
      "name": "settings",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"settings\" (\"key\" TEXT NOT NULL, \"value\" TEXT NOT NULL, PRIMARY KEY (\"key\"));"
        }
      ]
    }
  ]
