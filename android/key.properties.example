# Template for android/key.properties — COPY, do not edit this file in place.
#
#   cp android/key.properties.example android/key.properties
#
# The real android/key.properties is git-ignored and must never be committed.
# Keep both it and the .jks OUTSIDE the repo tree in normal use, plus an offline
# backup. See RELEASE.md for how to create the upload keystore.

storePassword=CHANGE_ME
keyPassword=CHANGE_ME
keyAlias=upload
# Absolute path to the upload keystore, kept outside the repo tree:
storeFile=/absolute/path/to/upload-keystore.jks
